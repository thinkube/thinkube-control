---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ namespace }}
  namespace: {{ namespace }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: {{ namespace }}-reader
rules:
# Core API resources
- apiGroups: [""]
  resources:
    - configmaps
    - services
    - pods
    - pods/log
    - namespaces
    - events
    - persistentvolumeclaims
    - persistentvolumes
    - endpoints
    - secrets
    - serviceaccounts
  verbs: ["get", "list", "watch"]

# Pod exec (LLM model creation via Ollama CLI)
- apiGroups: [""]
  resources:
    - pods/exec
  verbs: ["get", "create"]

# Node management (cordon/uncordon/drain/delete)
- apiGroups: [""]
  resources:
    - nodes
  verbs: ["get", "list", "watch", "patch", "update", "delete"]

# Apps resources (create/delete needed for LLM Gateway pod management)
- apiGroups: ["apps"]
  resources:
    - deployments
    - statefulsets
    - daemonsets
    - replicasets
  verbs: ["get", "list", "watch", "create", "patch", "update", "delete"]

# Batch resources
- apiGroups: ["batch"]
  resources:
    - jobs
    - cronjobs
  verbs: ["get", "list", "watch"]

# Networking (Gateway API + legacy Ingress for discovery)
- apiGroups: ["networking.k8s.io"]
  resources:
    - ingresses
    - networkpolicies
  verbs: ["get", "list", "watch"]
- apiGroups: ["gateway.networking.k8s.io"]
  resources:
    - httproutes
    - gateways
  verbs: ["get", "list", "watch"]

# Knative Serving (for Knative service management and dashboard)
- apiGroups: ["serving.knative.dev"]
  resources:
    - services
    - revisions
    - routes
    - configurations
  verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
- apiGroups: ["autoscaling.internal.knative.dev"]
  resources:
    - podautoscalers
  verbs: ["get", "list", "watch"]

# Autoscaling
- apiGroups: ["autoscaling"]
  resources:
    - horizontalpodautoscalers
  verbs: ["get", "list", "watch"]

# RBAC (for visibility, not modification)
- apiGroups: ["rbac.authorization.k8s.io"]
  resources:
    - roles
    - rolebindings
    - clusterroles
    - clusterrolebindings
  verbs: ["get", "list", "watch"]

# Custom Resource Definitions
- apiGroups: ["apiextensions.k8s.io"]
  resources:
    - customresourcedefinitions
  verbs: ["get", "list", "watch"]

# Metrics API (for node and pod metrics)
- apiGroups: ["metrics.k8s.io"]
  resources:
    - nodes
    - pods
  verbs: ["get", "list"]

# Argo Workflows + ArgoCD Applications
- apiGroups: ["argoproj.io"]
  resources:
    - workflows
    - workflowtemplates
    - cronworkflows
    - workflowtaskresults
    - applications
  verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: {{ namespace }}-reader
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: {{ namespace }}-reader
subjects:
- kind: ServiceAccount
  name: {{ namespace }}
  namespace: {{ namespace }}
- kind: ServiceAccount
  name: {{ namespace }}
  namespace: argo
