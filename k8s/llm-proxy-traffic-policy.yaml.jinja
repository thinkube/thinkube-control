apiVersion: gateway.envoyproxy.io/v1alpha1
kind: BackendTrafficPolicy
metadata:
  name: llm-proxy-timeout
  namespace: {{ namespace }}
spec:
  targetRefs:
    - group: gateway.networking.k8s.io
      kind: HTTPRoute
      name: llm-proxy-httproute
  timeout:
    http:
      connectionIdleTimeout: 600s
      maxConnectionDuration: 7200s
      requestTimeout: 600s
    tcp:
      connectTimeout: 30s
