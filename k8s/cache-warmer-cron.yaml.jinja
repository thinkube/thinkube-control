# CronWorkflow to periodically warm Kaniko cache
# Runs daily at 2 AM to ensure cache is fresh
# Multi-arch: when build_architectures has multiple entries, warms cache on each arch node
apiVersion: argoproj.io/v1alpha1
kind: CronWorkflow
metadata:
  name: kaniko-cache-warmer
  namespace: argo
spec:
  # Run daily at 2 AM
  schedule: "0 2 * * *"
  timezone: "UTC"
  concurrencyPolicy: "Replace"
  successfulJobsHistoryLimit: 3
  failedJobsHistoryLimit: 1
  workflowSpec:
    entrypoint: warm-cache
    serviceAccountName: kaniko-builder
    ttlStrategy:
      secondsAfterCompletion: 86400  # Clean up after 24 hours
    volumes:
    - name: docker-config
      secret:
        secretName: docker-config
    - name: kaniko-cache
      hostPath:
        path: /home/{{ system_username }}/.cache/kaniko
        type: DirectoryOrCreate
{% if build_architectures is defined and build_architectures | length > 1 %}
    - name: workspace
      emptyDir: {}
{% endif %}
    templates:
    - name: warm-cache
      dag:
        tasks:
{% if build_architectures is defined and build_architectures | length > 1 %}
{% for arch in build_architectures %}
        - name: warm-python-cache-{{ arch }}
          template: warm-image-cache-on-arch
          arguments:
            parameters:
            - name: image
              value: "{{ container_registry }}/library/python:3.12-slim"
            - name: target-arch
              value: "{{ arch }}"
        - name: warm-python-base-cache-{{ arch }}
          template: warm-image-cache-on-arch
          arguments:
            parameters:
            - name: image
              value: "{{ container_registry }}/library/python-base:3.12-slim"
            - name: target-arch
              value: "{{ arch }}"
        - name: warm-node-cache-{{ arch }}
          template: warm-image-cache-on-arch
          arguments:
            parameters:
            - name: image
              value: "{{ container_registry }}/library/node:18-alpine"
            - name: target-arch
              value: "{{ arch }}"
        - name: warm-node-base-cache-{{ arch }}
          template: warm-image-cache-on-arch
          arguments:
            parameters:
            - name: image
              value: "{{ container_registry }}/library/node-base:18-alpine"
            - name: target-arch
              value: "{{ arch }}"
        - name: warm-nginx-cache-{{ arch }}
          template: warm-image-cache-on-arch
          arguments:
            parameters:
            - name: image
              value: "{{ container_registry }}/library/nginx:stable-alpine"
            - name: target-arch
              value: "{{ arch }}"
{% endfor %}
{% else %}
        - name: warm-python-cache
          template: warm-image-cache
          arguments:
            parameters:
            - name: image
              value: "{{ container_registry }}/library/python:3.12-slim"
        - name: warm-python-base-cache
          template: warm-image-cache
          arguments:
            parameters:
            - name: image
              value: "{{ container_registry }}/library/python-base:3.12-slim"
        - name: warm-node-cache
          template: warm-image-cache
          arguments:
            parameters:
            - name: image
              value: "{{ container_registry }}/library/node:18-alpine"
        - name: warm-node-base-cache
          template: warm-image-cache
          arguments:
            parameters:
            - name: image
              value: "{{ container_registry }}/library/node-base:18-alpine"
        - name: warm-nginx-cache
          template: warm-image-cache
          arguments:
            parameters:
            - name: image
              value: "{{ container_registry }}/library/nginx:stable-alpine"
{% endif %}

{% if build_architectures is defined and build_architectures | length > 1 %}
    - name: warm-image-cache-on-arch
      nodeSelector:
        kubernetes.io/arch: "{% raw %}{{inputs.parameters.target-arch}}{% endraw %}"
        thinkube.io/build-node: "true"
      inputs:
        parameters:
        - name: image
        - name: target-arch
      container:
        image: {{ container_registry }}/library/kaniko-warmer:v1.24.0
        args:
          - --cache-dir=/cache
          - --image={% raw %}{{inputs.parameters.image}}{% endraw %}
        volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
        - name: kaniko-cache
          mountPath: /cache
{% endif %}

    - name: warm-image-cache
      nodeSelector:
        kubernetes.io/hostname: {{ master_node_name }}
      inputs:
        parameters:
        - name: image
      container:
        image: {{ container_registry }}/library/kaniko-warmer:v1.24.0
        args:
          - --cache-dir=/cache
          - --image={% raw %}{{inputs.parameters.image}}{% endraw %}
        volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
        - name: kaniko-cache
          mountPath: /cache
