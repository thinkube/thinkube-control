apiVersion: apps/v1
kind: Deployment
metadata:
  name: thinkube-control-llm-proxy
  namespace: {{ namespace }}
  labels:
    app: thinkube-control-llm-proxy
spec:
  replicas: 1
  selector:
    matchLabels:
      app: thinkube-control-llm-proxy
  template:
    metadata:
      labels:
        app: thinkube-control-llm-proxy
    spec:
      serviceAccountName: {{ namespace }}
      nodeSelector:
        kubernetes.io/hostname: {{ master_node_name }}
      containers:
      - name: llm-proxy
        image: {{ llm_proxy_image_repo }}
        imagePullPolicy: Always
        ports:
        - containerPort: 8080
        env:
        - name: BACKEND_URL
          value: "http://backend.{{ namespace }}.svc.cluster.local:8000"
        - name: LOG_LEVEL
          value: "info"
        - name: REQUEST_TIMEOUT_SECONDS
          value: "300"
        - name: MODEL_ALIASES
          value: "{}"
        - name: KEYCLOAK_URL
          value: "https://{{ auth_subdomain }}.{{ domain_name }}"
        - name: KEYCLOAK_REALM
          value: "{{ keycloak_realm }}"
        - name: KEYCLOAK_CLIENT_ID
          value: "thinkube-control"
        resources:
          requests:
            cpu: 100m
            memory: 128Mi
          limits:
            cpu: 500m
            memory: 512Mi
        livenessProbe:
          httpGet:
            path: /livez
            port: 8080
          initialDelaySeconds: 5
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 3
        readinessProbe:
          httpGet:
            path: /health
            port: 8080
          initialDelaySeconds: 3
          periodSeconds: 5
          timeoutSeconds: 5
      imagePullSecrets:
      - name: app-pull-secret
