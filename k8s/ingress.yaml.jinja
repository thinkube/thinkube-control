apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: {{ namespace }}-httproute
  namespace: {{ namespace }}
spec:
  parentRefs:
    - name: thinkube-gateway
      namespace: gateway-system
      sectionName: https
  hostnames:
    - {{ control_subdomain }}.{{ domain_name }}
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /mcp
      backendRefs:
        - name: backend
          port: 8000
    - matches:
        - path:
            type: PathPrefix
            value: /api
      backendRefs:
        - name: backend
          port: 8000
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: frontend
          port: 80
