# CI/CD Workflow for thinkube-control with Test-Driven Development
# This workflow is triggered by Gitea webhooks and builds container images
# Tests must pass before builds proceed
#
# Build Tool: Kaniko executor from Google (gcr.io/kaniko-project/executor:latest)
# Security: Runs as non-root user, no special privileges required
# Cache: Uses local cache directory only (no registry cache push to avoid permission issues)
#
# Multi-arch support: When build_architectures has multiple entries, builds run on
# per-arch nodes using git-clone init containers and creates manifest lists.
apiVersion: argoproj.io/v1alpha1
kind: WorkflowTemplate
metadata:
  name: {{ project_name }}-build
  namespace: argo
  labels:
    app.kubernetes.io/name: {{ project_name }}
    app.kubernetes.io/part-of: thinkube
    app.kubernetes.io/component: ci-cd
    thinkube.io/trigger: webhook
    thinkube.io/build-type: container
    # Critical for webhook adapter to identify the app
    thinkube.io/app-name: {{ project_name }}
    thinkube.io/namespace: {{ namespace }}
spec:
  entrypoint: build-and-push
  serviceAccountName: kaniko-builder  # ServiceAccount with Harbor registry credentials
  arguments:
    parameters:
    - name: webhook-timestamp
      value: ""  # Will be set by Argo Events sensor

  # Use artifact repository for build artifacts
  artifactRepositoryRef:
    configMap: artifact-repositories
    key: default-v1

  # Volumes
  volumes:
  - name: docker-config
    secret:
      secretName: docker-config
  - name: shared-code
    hostPath:
      path: /home/{{ system_username }}/shared-code/{{ project_name }}
      type: Directory
  - name: build-cache
    hostPath:
      path: /home/{{ system_username }}/.cache/thinkube-builds
      type: DirectoryOrCreate
  - name: workspace
    emptyDir: {}

  templates:
  - name: build-and-push
    dag:
      tasks:
{% if build_architectures is defined and build_architectures | length > 1 %}
      # Multi-arch: per-arch builds then manifest creation
{% for arch in build_architectures %}
      - name: build-backend-{{ arch }}
        template: build-on-arch
        arguments:
          parameters:
          - name: image-tag
            value: "{% raw %}{{workflow.uid}}{% endraw %}"
          - name: target-arch
            value: "{{ arch }}"
          - name: component
            value: "backend"
          - name: dockerfile
            value: "backend/Dockerfile"
          - name: context
            value: "backend"

      - name: build-frontend-{{ arch }}
        template: build-on-arch
        arguments:
          parameters:
          - name: image-tag
            value: "{% raw %}{{workflow.uid}}{% endraw %}"
          - name: target-arch
            value: "{{ arch }}"
          - name: component
            value: "frontend"
          - name: dockerfile
            value: "frontend/Dockerfile"
          - name: context
            value: "frontend"
{% endfor %}

      - name: manifest-backend
        dependencies:
{% for arch in build_architectures %}
          - build-backend-{{ arch }}
{% endfor %}
        template: create-manifest
        arguments:
          parameters:
          - name: image-tag
            value: "{% raw %}{{workflow.uid}}{% endraw %}"
          - name: component
            value: "backend"

      - name: manifest-frontend
        dependencies:
{% for arch in build_architectures %}
          - build-frontend-{{ arch }}
{% endfor %}
        template: create-manifest
        arguments:
          parameters:
          - name: image-tag
            value: "{% raw %}{{workflow.uid}}{% endraw %}"
          - name: component
            value: "frontend"
{% else %}
      # Single-arch builds on control plane
      - name: build-backend
        template: build-backend
        arguments:
          parameters:
          - name: image-tag
            value: "{% raw %}{{workflow.uid}}{% endraw %}"

      - name: build-frontend
        template: build-frontend
        arguments:
          parameters:
          - name: image-tag
            value: "{% raw %}{{workflow.uid}}{% endraw %}"
{% endif %}

  # Build Backend Template — single-arch on control plane
  - name: build-backend
    nodeSelector:
      kubernetes.io/hostname: {{ master_node_name }}
    inputs:
      parameters:
      - name: image-tag
    container:
      image: {{ container_registry }}/library/kaniko-executor:latest
      args:
      - --dockerfile=/workspace/backend/Dockerfile
      - --context=/workspace/backend
      - --destination={{ registry_subdomain }}.{{ domain_name }}/thinkube/thinkube-control-backend:{% raw %}{{inputs.parameters.image-tag}}{% endraw %}
      - --build-arg=REGISTRY={{ container_registry }}
      - --cache-dir=/workspace/.cache/kaniko
      volumeMounts:
      - name: docker-config
        mountPath: /kaniko/.docker
      - name: shared-code
        mountPath: /workspace
      - name: build-cache
        mountPath: /workspace/.cache
      resources:
        requests:
          memory: "1Gi"
          cpu: "1"
        limits:
          memory: "2Gi"
          cpu: "2"

  # Build Frontend Template — single-arch on control plane
  - name: build-frontend
    nodeSelector:
      kubernetes.io/hostname: {{ master_node_name }}
    inputs:
      parameters:
      - name: image-tag
    container:
      image: {{ container_registry }}/library/kaniko-executor:latest
      args:
      - --dockerfile=/workspace/frontend/Dockerfile
      - --context=/workspace/frontend
      - --destination={{ registry_subdomain }}.{{ domain_name }}/thinkube/thinkube-control-frontend:{% raw %}{{inputs.parameters.image-tag}}{% endraw %}
      - --build-arg=REGISTRY={{ container_registry }}
      - --cache-dir=/workspace/.cache/kaniko
      volumeMounts:
      - name: docker-config
        mountPath: /kaniko/.docker
      - name: shared-code
        mountPath: /workspace
      - name: build-cache
        mountPath: /workspace/.cache
      resources:
        requests:
          memory: "2Gi"
          cpu: "1"
        limits:
          memory: "4Gi"
          cpu: "2"

{% if build_architectures is defined and build_architectures | length > 1 %}
  # Per-arch build with git-clone init container
  - name: build-on-arch
    nodeSelector:
      kubernetes.io/arch: "{% raw %}{{inputs.parameters.target-arch}}{% endraw %}"
      thinkube.io/build-node: "true"
    inputs:
      parameters:
      - name: image-tag
      - name: target-arch
      - name: component
      - name: dockerfile
      - name: context
    initContainers:
      - name: git-clone
        image: {{ container_registry }}/library/ci-utils:latest
        command: ["/bin/sh", "-c"]
        args:
          - |
            git clone --depth 1 https://gitea.{{ domain_name }}/{{ gitea_org | default('thinkube') }}/{{ project_name }}.git /workspace
        volumeMounts:
          - name: workspace
            mountPath: /workspace
    container:
      image: {{ container_registry }}/library/kaniko-executor:latest
      args:
      - --dockerfile=/workspace/{% raw %}{{inputs.parameters.dockerfile}}{% endraw %}
      - --context=/workspace/{% raw %}{{inputs.parameters.context}}{% endraw %}
      - --destination={{ registry_subdomain }}.{{ domain_name }}/thinkube/thinkube-control-{% raw %}{{inputs.parameters.component}}{% endraw %}:{% raw %}{{inputs.parameters.image-tag}}{% endraw %}-{% raw %}{{inputs.parameters.target-arch}}{% endraw %}
      - --build-arg=REGISTRY={{ container_registry }}
      - --cache-dir=/cache/kaniko
      - --custom-platform=linux/{% raw %}{{inputs.parameters.target-arch}}{% endraw %}
      volumeMounts:
      - name: docker-config
        mountPath: /kaniko/.docker
      - name: workspace
        mountPath: /workspace
      resources:
        requests:
          memory: "2Gi"
          cpu: "1"
        limits:
          memory: "4Gi"
          cpu: "2"

  # Create multi-arch manifest from per-arch images using crane
  - name: create-manifest
    inputs:
      parameters:
      - name: image-tag
      - name: component
    container:
      image: {{ container_registry }}/library/crane:latest
      command: ["/bin/sh", "-c"]
      env:
        - name: DOCKER_CONFIG
          value: /kaniko/.docker
      args:
        - |
          set -e
          IMAGE="{{ registry_subdomain }}.{{ domain_name }}/thinkube/thinkube-control-{% raw %}{{inputs.parameters.component}}{% endraw %}"
          TAG="{% raw %}{{inputs.parameters.image-tag}}{% endraw %}"

          echo "Creating multi-arch manifest for ${IMAGE}:${TAG}"
          crane index append --tag "${IMAGE}:${TAG}" \
{% for arch in build_architectures %}
            --manifest "${IMAGE}:${TAG}-{{ arch }}"{{ " \\" if not loop.last else "" }}
{% endfor %}

          crane tag "${IMAGE}:${TAG}" latest
          echo "Multi-arch manifest pushed"
      volumeMounts:
      - name: docker-config
        mountPath: /kaniko/.docker
{% endif %}
