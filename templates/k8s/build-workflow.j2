# Generated Argo Workflow template for building and testing containers
# Supports multi-architecture builds when cluster has nodes of different architectures
---
apiVersion: argoproj.io/v1alpha1
kind: WorkflowTemplate
metadata:
  name: {{ project_name }}-build
  namespace: argo
  labels:
    app.kubernetes.io/name: {{ project_name }}
    app.kubernetes.io/part-of: thinkube
    app.kubernetes.io/component: ci-cd
    thinkube.io/trigger: webhook
    thinkube.io/build-type: container
    # Critical for webhook adapter to identify the app
    thinkube.io/app-name: {{ project_name }}
    thinkube.io/namespace: {{ k8s_namespace }}
spec:
  entrypoint: ci-cd-pipeline

  # Service account for Kaniko builds
  serviceAccountName: kaniko-builder

  # Global parameters - webhook-timestamp comes from Argo Events
  arguments:
    parameters:
      - name: webhook-timestamp
        value: ""  # Set by Argo Events sensor
      - name: image_tag
        value: "{{ "{{" }}workflow.uid{{ "}}" }}"

  # Volumes for builds and tests
  volumes:
    - name: docker-config
      secret:
        secretName: harbor-docker-config
        items:
          - key: config.json
            path: config.json
    - name: shared-code
      hostPath:
        path: /home/{{ system_username }}/shared-code/apps/{{ project_name }}
        type: Directory
    - name: workspace
      emptyDir: {}

  templates:
    - name: ci-cd-pipeline
      dag:
        tasks:
{% for container in thinkube_spec.spec.containers %}
        # {{ container.name }} test (conditional)
        - name: test-{{ container.name }}
          template: execute-container-test
          arguments:
            parameters:
              - name: container_name
                value: "{{ container.name }}"
              - name: build_path
                value: "{{ container.build | replace('./', '') }}"
              - name: test_enabled
                value: "{% if container.test is defined %}{{ container.test.enabled | default(true) | lower }}{% else %}false{% endif %}"
              - name: test_command
                value: "{% if container.test is defined %}{{ container.test.command | default('') }}{% endif %}"
              - name: test_image
                value: "{% if container.test is defined and container.test.image is defined %}{% if '/' in container.test.image %}{{ container.test.image }}{% else %}{{ container_registry }}/library/{{ container.test.image }}{% endif %}{% else %}{{ container_registry }}/library/test-runner:latest{% endif %}"

{% if build_architectures is defined and build_architectures | length > 1 %}
        # Per-architecture builds for {{ container.name }}
{% for arch in build_architectures %}
        - name: build-{{ container.name }}-{{ arch }}
          dependencies: [test-{{ container.name }}]
          template: kaniko-build-on-arch
          arguments:
            parameters:
              - name: container_name
                value: "{{ container.name }}"
              - name: dockerfile_path
                value: "{{ container.build | replace('./', '') }}/Dockerfile"
              - name: context_path
                value: "{{ container.build | replace('./', '') }}"
              - name: target_arch
                value: "{{ arch }}"
{% endfor %}

        # Create multi-arch manifest for {{ container.name }}
        - name: manifest-{{ container.name }}
          dependencies:
{% for arch in build_architectures %}
            - build-{{ container.name }}-{{ arch }}
{% endfor %}
          template: create-manifest
          arguments:
            parameters:
              - name: container_name
                value: "{{ container.name }}"
{% else %}
        # Single-architecture build for {{ container.name }}
        - name: build-{{ container.name }}
          dependencies: [test-{{ container.name }}]
          template: kaniko-build
          arguments:
            parameters:
              - name: container_name
                value: "{{ container.name }}"
              - name: dockerfile_path
                value: "{{ container.build | replace('./', '') }}/Dockerfile"
              - name: context_path
                value: "{{ container.build | replace('./', '') }}"
{% endif %}
{% endfor %}

    # Template to execute container tests
    - name: execute-container-test
      inputs:
        parameters:
          - name: container_name
          - name: build_path
          - name: test_enabled
          - name: test_command
          - name: test_image
      steps:
        - - name: check-test-enabled
            template: check-condition
            arguments:
              parameters:
                - name: condition
                  value: "{{ "{{" }}inputs.parameters.test_enabled{{ "}}" }}"
        - - name: run-test
            when: "{{ "{{" }}steps.check-test-enabled.outputs.result{{ "}}" }} == true"
            template: run-test
            arguments:
              parameters:
                - name: container_name
                  value: "{{ "{{" }}inputs.parameters.container_name{{ "}}" }}"
                - name: build_path
                  value: "{{ "{{" }}inputs.parameters.build_path{{ "}}" }}"
                - name: test_command
                  value: "{{ "{{" }}inputs.parameters.test_command{{ "}}" }}"
                - name: test_image
                  value: "{{ "{{" }}inputs.parameters.test_image{{ "}}" }}"

    # Template that runs the actual test
    - name: run-test
      nodeSelector:
        kubernetes.io/hostname: {{ master_node_name }}
      inputs:
        parameters:
          - name: container_name
          - name: build_path
          - name: test_command
          - name: test_image
      container:
        image: "{{ "{{" }}inputs.parameters.test_image{{ "}}" }}"
        imagePullPolicy: Always
        command: ["/bin/sh", "-c"]
        env:
          - name: ADMIN_USERNAME
            value: "{{ admin_username }}"
          - name: ADMIN_PASSWORD
            value: "{{ admin_password }}"
        args:
          - |
            set -e
            cd /workspace/{{ "{{" }}inputs.parameters.build_path{{ "}}" }}

            # Get test command - MUST be provided, no auto-detection
            TEST_CMD="{{ "{{" }}inputs.parameters.test_command{{ "}}" }}"

            # If test is enabled but no command provided, FAIL
            if [ -z "$TEST_CMD" ]; then
              echo "ERROR: Tests are enabled but no test command was specified in thinkube.yaml"
              echo "Please add test.command to your container configuration"
              exit 1
            fi

            # Run the provided test command
            echo "Running tests: $TEST_CMD"
            $TEST_CMD
        volumeMounts:
          - name: shared-code
            mountPath: /workspace
        resources:
          requests:
            memory: "512Mi"
            cpu: "500m"
          limits:
            memory: "1Gi"
            cpu: "1"

    # Single-arch Kaniko build (runs on control plane with hostPath)
    - name: kaniko-build
      nodeSelector:
        kubernetes.io/hostname: {{ master_node_name }}
      inputs:
        parameters:
          - name: container_name
          - name: dockerfile_path
          - name: context_path
      container:
        image: {{ container_registry }}/library/kaniko-executor:v1.24.0
        args:
          - "--dockerfile=/workspace/{{ "{{" }}inputs.parameters.dockerfile_path{{ "}}" }}"
          - "--context=/workspace/{{ "{{" }}inputs.parameters.context_path{{ "}}" }}"
          - "--destination={{ container_registry }}/thinkube/{{ project_name }}-{{ "{{" }}inputs.parameters.container_name{{ "}}" }}:{{ "{{" }}workflow.parameters.image_tag{{ "}}" }}"
          - "--destination={{ container_registry }}/thinkube/{{ project_name }}-{{ "{{" }}inputs.parameters.container_name{{ "}}" }}:latest"
          - "--build-arg=CONTAINER_REGISTRY={{ container_registry }}"
          - "--cache=true"
          - "--cache-ttl=24h"
        volumeMounts:
          - name: docker-config
            mountPath: /kaniko/.docker/
          - name: shared-code
            mountPath: /workspace

{% if build_architectures is defined and build_architectures | length > 1 %}
    # Per-arch Kaniko build with git-clone init container for worker nodes
    - name: kaniko-build-on-arch
      nodeSelector:
        kubernetes.io/arch: "{{ "{{" }}inputs.parameters.target_arch{{ "}}" }}"
        thinkube.io/build-node: "true"
      inputs:
        parameters:
          - name: container_name
          - name: dockerfile_path
          - name: context_path
          - name: target_arch
      initContainers:
        - name: git-clone
          image: {{ container_registry }}/library/ci-utils:latest
          command: ["/bin/sh", "-c"]
          args:
            - |
              git clone --depth 1 https://gitea.{{ domain_name }}/{{ gitea_org | default('thinkube') }}/{{ project_name }}.git /workspace
          volumeMounts:
            - name: workspace
              mountPath: /workspace
      container:
        image: {{ container_registry }}/library/kaniko-executor:v1.24.0
        args:
          - "--dockerfile=/workspace/{{ "{{" }}inputs.parameters.dockerfile_path{{ "}}" }}"
          - "--context=/workspace/{{ "{{" }}inputs.parameters.context_path{{ "}}" }}"
          - "--destination={{ container_registry }}/thinkube/{{ project_name }}-{{ "{{" }}inputs.parameters.container_name{{ "}}" }}:{{ "{{" }}workflow.parameters.image_tag{{ "}}" }}-{{ "{{" }}inputs.parameters.target_arch{{ "}}" }}"
          - "--build-arg=CONTAINER_REGISTRY={{ container_registry }}"
          - "--cache=true"
          - "--cache-ttl=24h"
          - "--custom-platform=linux/{{ "{{" }}inputs.parameters.target_arch{{ "}}" }}"
        volumeMounts:
          - name: docker-config
            mountPath: /kaniko/.docker/
          - name: workspace
            mountPath: /workspace

    # Create multi-arch manifest list from per-arch images using crane
    - name: create-manifest
      inputs:
        parameters:
          - name: container_name
      container:
        image: {{ container_registry }}/library/crane:latest
        command: ["/bin/sh", "-c"]
        env:
          - name: DOCKER_CONFIG
            value: /kaniko/.docker
        args:
          - |
            set -e
            IMAGE="{{ container_registry }}/thinkube/{{ project_name }}-{{ "{{" }}inputs.parameters.container_name{{ "}}" }}"
            TAG="{{ "{{" }}workflow.parameters.image_tag{{ "}}" }}"

            echo "Creating multi-arch manifest for ${IMAGE}:${TAG}"

            # Create manifest list from per-arch images
            crane index append --tag "${IMAGE}:${TAG}" \
{% for arch in build_architectures %}
              --manifest "${IMAGE}:${TAG}-{{ arch }}"{{ " \\" if not loop.last else "" }}
{% endfor %}

            # Also tag as :latest
            crane tag "${IMAGE}:${TAG}" latest

            echo "Multi-arch manifest created and pushed"
        volumeMounts:
          - name: docker-config
            mountPath: /kaniko/.docker
{% endif %}

    # Helper template to check conditions
    - name: check-condition
      inputs:
        parameters:
          - name: condition
      script:
        image: {{ container_registry }}/library/ci-utils:latest
        imagePullPolicy: Always
        command: [bash]
        source: |
          if [ "{{ "{{" }}inputs.parameters.condition{{ "}}" }}" = "true" ]; then
            echo "true"
          else
            echo "false"
          fi
